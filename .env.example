# ───────── Flask ─────────
FLASK_ENV=development
SECRET_KEY=change-me

# ───────── Database (MySQL via PyMySQL) ─────────
# Format: mysql+pymysql://USER:PASSWORD@HOST:PORT/DB?charset=utf8mb4
DATABASE_URL=mysql+pymysql://flaskpos:GantiPasswordKuat!123@127.0.0.1:3306/flask_pos?charset=utf8mb4

# ───────── Pooling & Tuning (opsional) ─────────
DB_POOL_SIZE=5
DB_MAX_OVERFLOW=10
DB_POOL_RECYCLE=280
DB_POOL_TIMEOUT=30

# ───────── SQLAlchemy (opsional) ─────────
SQLALCHEMY_ECHO=false
SQLALCHEMY_TRACK_MODIFICATIONS=false
